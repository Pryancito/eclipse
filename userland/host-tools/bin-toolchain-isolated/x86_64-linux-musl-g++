#!/usr/bin/env bash
set -e
d="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$d/../../.." && pwd)"
for TC in "$ROOT/eclipse-os-build" "$ROOT/host-toolchains"; do
	BIN="$TC/bin/x86_64-linux-musl-g++"
	if [[ -x "$BIN" ]]; then
		export LD_LIBRARY_PATH="$TC/lib"
		exec "$BIN" "$@"
	fi
done
echo "no se encontró x86_64-linux-musl-g++ bajo $ROOT" >&2
exit 127
