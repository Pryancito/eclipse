#!/usr/bin/env bash
set -e
d="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$d/../../.." && pwd)"
for TC in "$ROOT/eclipse-os-build" "$ROOT/host-toolchains"; do
	BIN="$TC/bin/x86_64-linux-musl-strip"
	if [[ -x "$BIN" ]]; then
		exec "$BIN" "$@"
	fi
done
# último recurso: strip del PATH
if command -v strip >/dev/null; then
	exec strip "$@"
fi
exit 127
