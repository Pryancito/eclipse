#!/bin/sh
# Ejemplo de sesión X para TinyX (Xfbdev) en Eclipse OS.
#
# Se asume que Xfbdev ya está corriendo y que DISPLAY apunta a él, p. ej.:
#   Xfbdev :0 -screen 1024x768 -mouse /dev/input/mice vt1 &
#   export DISPLAY=:0
#   sh /etc/X11/xinitrc.tinyx
#
# TinyX no incluye XKB; el teclado usa el keymap de la consola. Ajusta los
# clientes a lo que tengas instalado en el rootfs.

# Fondo y un par de clientes de prueba (si están disponibles).
command -v xsetroot >/dev/null 2>&1 && xsetroot -solid steelblue
command -v xclock   >/dev/null 2>&1 && xclock -geometry 120x120-0+0 &

# Un gestor de ventanas mínimo, si existe (twm/tinywm/evilwm…).
for wm in twm tinywm evilwm; do
    if command -v "$wm" >/dev/null 2>&1; then
        "$wm" &
        break
    fi
done

# Cliente principal: una terminal. Mantenerla en primer plano hace que, al
# cerrarla, termine la sesión X.
if command -v xterm >/dev/null 2>&1; then
    exec xterm -geometry 80x24+0+0
fi

# Sin xterm: deja la sesión viva para inspeccionar con otros clientes.
exec sleep infinity
